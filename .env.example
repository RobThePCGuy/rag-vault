# RAG-Vault Environment Variables
# Copy this file to .env and customize as needed

# ===========================================
# API Authentication
# ===========================================
# Optional API key for securing the HTTP server
# Leave empty for local-only mode (no authentication required)
# RAG_API_KEY=your-secret-api-key-here

# ===========================================
# CORS Configuration
# ===========================================
# Comma-separated list of allowed origins, or "*" for all origins
# Default: http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ===========================================
# Request Limits
# ===========================================
# Maximum JSON body size for requests (default: 5mb)
# JSON_BODY_LIMIT=5mb

# ===========================================
# Database Scanning
# ===========================================
# Comma-separated list of directories allowed for database scanning
# Default: user's home directory
# ALLOWED_SCAN_ROOTS=/home/user/documents,/home/user/projects

# ===========================================
# Rate Limiting
# ===========================================
# Time window for rate limiting in milliseconds (default: 60000 = 1 minute)
# RATE_LIMIT_WINDOW_MS=60000

# Maximum requests per window (default: 100)
# RATE_LIMIT_MAX_REQUESTS=100

# ===========================================
# Logging
# ===========================================
# Enable detailed request logging (default: false)
# Set to "true" for debugging
# REQUEST_LOGGING=false

# ===========================================
# Embedding Runtime
# ===========================================
# Transformers.js device hint (default: auto)
# Common values: auto, cpu, cuda, dml, webgpu
# RAG_EMBEDDING_DEVICE=auto

# ===========================================
# Search Mode
# ===========================================
# Fusion mode for combining vector and BM25 results
# "boost" = legacy multiplicative keyword boost (default)
# "rrf" = Reciprocal Rank Fusion (independent voters, can surface docs vector search misses)
# RAG_SEARCH_MODE=boost

# RRF smoothing constant (only applies in rrf mode, default: 60)
# RAG_RRF_K=60

# ===========================================
# Cross-Encoder Reranking (opt-in)
# ===========================================
# Enable cross-encoder reranking for more precise relevance scoring
# RAG_RERANKER_ENABLED=false

# HuggingFace cross-encoder model (~23MB ONNX, downloads on first use)
# RAG_RERANKER_MODEL=Xenova/ms-marco-MiniLM-L-6-v2

# Fetch this many extra candidates for the reranker to score (default: 2)
# RAG_RERANKER_CANDIDATE_MULTIPLIER=2

# Inference device for the reranker (default: auto)
# RAG_RERANKER_DEVICE=auto

# Timeout for model download and initialization in ms (default: 600000 = 10 min)
# RERANKER_INIT_TIMEOUT_MS=600000

# ===========================================
# Query Expansion / HyDE (opt-in)
# ===========================================
# Enable query expansion for improved recall
# RAG_HYDE_ENABLED=false

# Backend: "rule-based" for local template expansion, "api" for LLM-based HyDE
# Note: "api" sends query text to an external endpoint, breaking the zero-cloud guarantee
# RAG_HYDE_BACKEND=rule-based

# Number of expanded queries to generate (default: 2)
# RAG_HYDE_EXPANSIONS=2

# API settings (only used when RAG_HYDE_BACKEND=api)
# RAG_HYDE_API_KEY=your-api-key-here
# RAG_HYDE_API_BASE_URL=https://api.anthropic.com
# RAG_HYDE_API_MODEL=claude-haiku-4-5-20251001

# ===========================================
# Server Configuration
# ===========================================
# Port for the HTTP server (default: 3000)
# WEB_PORT=3000
